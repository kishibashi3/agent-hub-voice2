# voice-gateway v2 環境変数テンプレート
# cp .env.example .env して値を設定すること

# LiveKit
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash-live-001

# agent-hub
AGENT_HUB_URL=http://localhost:3000
AGENT_HUB_USER=voice
AGENT_HUB_GITHUB_PAT=your-pat
AGENT_HUB_TENANT=
