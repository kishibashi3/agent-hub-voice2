# voice-gateway v2 環境変数テンプレート
# cp .env.example .env して値を設定すること

# LiveKit
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash-live-001

# agent-hub
# NOTE: Docker コンテナ内から Pi5 ホストに接続する場合は localhost ではなく
#       Pi5 の LAN IP を使う (例: http://192.168.1.10:3000/mcp)。
#       agent-hub は /mcp パスで MCP エンドポイントを提供している。
AGENT_HUB_URL=http://192.168.1.10:3000/mcp
AGENT_HUB_USER=voice
AGENT_HUB_GITHUB_PAT=your-pat
AGENT_HUB_TENANT=
